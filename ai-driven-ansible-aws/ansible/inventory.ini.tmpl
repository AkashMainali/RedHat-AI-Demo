# Rendered by scripts/bootstrap.sh from Terraform outputs (via envsubst).
# Contains ONLY public/non-secret connection data. The private key is
# referenced by PATH, never embedded. This rendered file is git-ignored.

[control]
control-node ansible_host=${CONTROL_PUBLIC_IP}

[target]
target-node ansible_host=${TARGET_PUBLIC_IP}

[control:vars]
control_public_ip=${CONTROL_PUBLIC_IP}
control_private_ip=${CONTROL_PRIVATE_IP}

[target:vars]
# Filebeat on the target ships to Kafka on the control node's PRIVATE IP.
kafka_host=${CONTROL_PRIVATE_IP}
control_private_ip=${CONTROL_PRIVATE_IP}

[all:vars]
ansible_user=${SSH_USER}
ansible_ssh_private_key_file=${SSH_KEY_PATH}
ansible_python_interpreter=/usr/bin/python3
